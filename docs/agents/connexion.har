              "text": "(function () {\n    const divGlobale= document.getElementById('chatmd');\n    const fab       = document.getElementById('chatmd-fab');\n    const panel     = document.getElementById('chatmd-panel');\n    const backdrop  = document.getElementById('chatmd-backdrop');\n    const closeBtn  = document.getElementById('chatmd-close');\n    const reinitBtn = document.getElementById('chatmd-reinit');\n    const iframe    = document.getElementById('chatmd-iframe');\n\n    // Encart (teaser)\n    const teaser    = document.getElementById('chatmd-teaser');\n    const teaserCTA = document.getElementById('chatmd-teaser-cta');\n    const teaserX   = document.querySelector('.chatmd-teaser-close');\n\n    if (!divGlobale) return;\n\n    fetch(\"/api/CHATMD\")\n        .then((response) => response.json())\n        .then((feature) => {\n            if (feature.enabled) {\n                divGlobale.hidden = false;\n                divGlobale.setAttribute('aria-hidden','false');\n            } else {\n                divGlobale.hidden = true;\n                divGlobale.setAttribute('aria-hidden','true');\n            }\n        });\n\n    if (!fab || !panel || !backdrop) return;\n\n    let lastActive = null;\n\n    // Clé de session pour mémoriser la fermeture de l’encart\n    const STORAGE_KEY = 'chatmdTeaserDisabled';\n    let teaserDisabled = false;\n\n    try {\n        teaserDisabled = sessionStorage.getItem(STORAGE_KEY) === '1';\n    } catch (e) {\n        // Si sessionStorage n’est pas dispo, on fait sans persistance\n        teaserDisabled = false;\n    }\n\n    const FOCUSABLE = [\n        'a[href]', 'area[href]',\n        'button:not([disabled])',\n        'input:not([disabled])',\n        'select:not([disabled])', 'textarea:not([disabled])',\n        'iframe', 'object', 'embed',\n        '[contenteditable]',\n        '[tabindex]:not([tabindex^=\"-\"])'\n    ].join(',');\n\n    /* ---------- Helpers visibilité FAB ---------- */\n    function showFab(){\n        fab.style.display = 'inline-flex';   // conforme à ton CSS\n        fab.removeAttribute('aria-hidden');\n    }\n    function hideFab(){\n        fab.style.display = 'none';\n        fab.setAttribute('aria-hidden','true');\n    }\n\n    /* ---------- Encart ---------- */\n    function showTeaser(){\n        if (!teaser) return;\n        teaser.hidden = false;\n        teaser.setAttribute('aria-hidden','false');\n    }\n    function hideTeaser(){\n        if (!teaser) return;\n        teaser.hidden = true;\n        teaser.setAttribute('aria-hidden','true');\n    }\n    function toggleTeaser(){\n        if (!teaser) return;\n        const isHidden = teaser.hidden || teaser.getAttribute('aria-hidden') === 'true';\n        isHidden ? showTeaser() : hideTeaser();\n    }\n\n    // Ouvert par défaut au chargement\n    function disableTeaserPermanently(){\n        hideTeaser();\n        teaserDisabled = true;\n        try {\n            sessionStorage.setItem(STORAGE_KEY, '1');\n        } catch (e) {\n            // pas grave si on ne peut pas persister\n        }\n    }\n\n    // Ouvert par défaut au chargement… sauf si l’utilisateur l’a déjà fermé\n    if (!teaserDisabled) {\n        showTeaser();\n    } else {\n        hideTeaser();\n    }\n\n    // (optionnel) si des onclick inline existaient\n    window.chatmdToggleTeaser = toggleTeaser;\n\n    /* ---------- Panneau (iframe) ---------- */\n    function ensureClosedOnInit() {\n        panel.classList.remove('open');\n        backdrop.classList.remove('open');\n        panel.hidden = true;\n        backdrop.hidden = true;\n        panel.setAttribute('aria-hidden', 'true');\n        backdrop.setAttribute('aria-hidden', 'true');\n        fab.setAttribute('aria-expanded', 'false');\n        showFab(); // le bouton doit être visible quand c'est fermé\n    }\n    ensureClosedOnInit();\n\n    function trapFocus(e) {\n        if (e.key !== 'Tab') return;\n        const nodes = panel.querySelectorAll(FOCUSABLE);\n        const focusables = Array.prototype.filter.call(nodes, el => {\n            const style = window.getComputedStyle(el);\n            const isHidden = el.hasAttribute('hidden') || style.display === 'none' || style.visibility === 'hidden';\n            return !isHidden;\n        });\n        if (!focusables.length) return;\n\n        const first = focusables[0];\n        const last  = focusables[focusables.length - 1];\n\n        if (e.shiftKey && document.activeElement === first) {\n            last.focus(); e.preventDefault();\n        } else if (!e.shiftKey && document.activeElement === last) {\n            first.focus(); e.preventDefault();\n        }\n    }\n\n    function openPanel() {\n        lastActive = document.activeElement;\n\n        panel.hidden = false;\n        backdrop.hidden = false;\n        panel.setAttribute('aria-hidden', 'false');\n        backdrop.setAttribute('aria-hidden', 'false');\n        panel.classList.add('open');\n        backdrop.classList.add('open');\n        fab.setAttribute('aria-expanded', 'true');\n\n        // Masquer l'encart et le bouton d'ouverture pendant l'affichage du panneau\n        hideTeaser();\n        hideFab();\n\n        panel.focus();\n        setTimeout(() => { if (closeBtn) closeBtn.focus(); }, 0);\n\n        document.addEventListener('keydown', trapFocus);\n        document.addEventListener('keydown', onEscClose);\n        backdrop.addEventListener('click', closePanel, { once: true });\n        document.body.style.overflow = 'hidden';\n    }\n\n    function closePanel() {\n        panel.classList.remove('open');\n        backdrop.classList.remove('open');\n\n        panel.hidden = true;\n        backdrop.hidden = true;\n        panel.setAttribute('aria-hidden', 'true');\n        backdrop.setAttribute('aria-hidden', 'true');\n        fab.setAttribute('aria-expanded', 'false');\n\n        document.removeEventListener('keydown', trapFocus);\n        document.removeEventListener('keydown', onEscClose);\n        document.body.style.overflow = '';\n\n        // Ré-affiche le bouton d'ouverture AVANT de rendre le focus\n        showFab();\n\n        if (lastActive && typeof lastActive.focus === 'function') {\n            // si le dernier focus était le FAB, il est de nouveau visible\n            lastActive.focus();\n        }\n\n        // On ne ré-affiche l'encart qu'aux utilisateurs qui ne l'ont pas “désactivé”\n        if (!teaserDisabled) {\n            showTeaser();\n        }\n    }\n\n    function onEscClose(e) {\n        if (e.key === 'Escape' && !panel.hidden) closePanel();\n    }\n\n    /* ---------- Bind UI ---------- */\n\n    // Le FAB toggle l'encart (ne touche pas au panneau)\n    fab.addEventListener('click', toggleTeaser);\n\n    // Seul le lien dans l'encart ouvre le panneau\n    teaserCTA?.addEventListener('click', (e) => {\n        e.preventDefault();\n        openPanel();\n    });\n\n    // La croix : cache l'encart et le désactive pour toute la “visite”\n    teaserX?.addEventListener('click', disableTeaserPermanently);\n\n    // Réinitialiser l'iframe\n    if (reinitBtn && iframe) {\n        reinitBtn.setAttribute('aria-label', 'Réinitialiser la conversation');\n        const icon = reinitBtn.querySelector('[aria-hidden]');\n        if (icon) icon.textContent = '↻';\n\n        const addCacheBust = (src) => {\n            const parts = String(src).split('#');\n            const url = parts[0];\n            const hash = parts[1] ? '#' + parts[1] : '';\n            const sep = url.includes('?') ? '&' : '?';\n            return url + sep + '_t=' + Date.now() + hash;\n        };\n\n        reinitBtn.addEventListener('click', () => {\n            reinitBtn.classList.add('is-reloading');\n            const stop = () => {\n                reinitBtn.classList.remove('is-reloading');\n                iframe.removeEventListener('load', stop);\n            };\n            iframe.addEventListener('load', stop);\n\n            const current = iframe.getAttribute('src') || '';\n            iframe.setAttribute('src', addCacheBust(current));\n        });\n    }\n\n    // Bouton \"Fermer\" du panneau\n    if (closeBtn) closeBtn.addEventListener('click', closePanel);\n\n})();"
            },
            "redirectURL": "",
            "headersSize": 607,
            "bodySize": 7982,
