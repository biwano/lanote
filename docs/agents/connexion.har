              "text": "/* Tokens DSFR avec fallbacks */\n:root {\n    --cm-shadow: var(--overlap-shadow, 0 8px 24px rgba(0,0,0,.18), 0 2px 8px rgba(0,0,0,.08));\n\n    --cm-action-bg-hover: var(--background-action-high-blue-france-hover, #1919ff);\n    --cm-action-bg-active: var(--background-action-high-blue-france-active, #00006d);\n\n    --cm-radius-lg: 14px;\n    --cm-radius-md: 10px;\n    --cm-radius-pill: 999px;\n\n    --cm-z: 2147483000;\n}\n\n/* Accessibilité : réduire les animations si demandé */\n@media (prefers-reduced-motion: reduce) {\n    * { animation: none !important; transition: none !important; }\n}\n\n/* ===== FAB (bouton lanceur)  inchangé visuellement, DSFRis ===== */\n#chatmd-fab {\n    position: fixed;\n    inset-inline-end: 20px;\n    inset-block-end: 20px;\n    width: 56px;\n    height: 56px;\n    min-width: 56px;\n    min-height: 56px;\n    border: 0;\n    border-radius: var(--cm-radius-pill);\n    background: var(--bf500);\n    color: var(--w-bf500);\n    font-size: 20px;\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    box-shadow: var(--cm-shadow);\n    cursor: pointer;\n    z-index: var(--cm-z);\n    transition: transform 120ms ease, background 120ms ease, box-shadow 120ms ease;\n}\n#chatmd-fab:hover { background: var(--cm-action-bg-hover); transform: translateY(-1px); }\n#chatmd-fab:active,\n#chatmd-fab[aria-expanded=\"true\"] { background: var(--cm-action-bg-active); transform: none; }\n#chatmd-fab:focus-visible {\n    outline: 2px solid var(--bf500);\n    outline-offset: 3px;\n    box-shadow: 0 0 0 4px color-mix(in srgb, var(--bf500) 25%, transparent), var(--cm-shadow);\n}\n\n/* ===== Backdrop (comme avant, discret) ===== */\n#chatmd-backdrop.chatmd-backdrop {\n    position: fixed;\n    inset: 0;\n    background: rgba(0,0,0,.45);\n    opacity: 0;\n    visibility: hidden;\n    transition: opacity 180ms ease, visibility 180ms ease;\n    z-index: calc(var(--cm-z) - 1);\n}\n\n/* ===== Panneau  dimensions d'avant ===== */\n#chatmd-panel.chatmd-panel {\n    position: fixed;\n    inset-inline-end: 20px;\n    inset-block-end: 84px; /* laisse la place au FAB en bas */\n    width: min(420px, 92vw);\n    height: min(72vh, 720px);\n    background: var(--w-bf500);\n    color: var(--g800-plain);\n    border: 1px solid var(--g400);\n    border-radius: var(--cm-radius-lg);\n    box-shadow: var(--cm-shadow);\n    overflow: hidden;\n    transform: translateY(8px);\n    opacity: 0;\n    visibility: hidden;\n    transition: opacity 180ms ease, transform 180ms ease, visibility 180ms ease;\n    z-index: var(--cm-z);\n}\n\n\n/* Ouvert (ton JS enlève aria-hidden) */\n#chatmd-panel[aria-modal=\"true\"][aria-hidden=\"false\"],\n#chatmd-panel[aria-modal=\"true\"]:not([aria-hidden]) {\n    transform: translateY(0);\n    opacity: 1;\n    visibility: visible;\n}\n\n/* ===== Header du panneau ===== */\n#chatmd-panel .chatmd-header {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: .5rem;\n    padding: .75rem 1rem;\n    background: var(--g200);\n    border-bottom: 1px solid var(--g400);\n}\n#chatmd-panel .chatmd-title {\n    font-size: 1rem;\n    line-height: 1.3;\n    margin: 0;\n    font-weight: 600;\n    color: var(--bf500);\n}\n#chatmd-panel .chatmd-actions { display: inline-flex; gap: .25rem; }\n\n/* ===== Boutons d'action header (Fermer / Popout) ===== */\n.chatmd-btn {\n    appearance: none;\n    border: 1px solid var(--g400);\n    background: transparent;\n    color: var(--g800-plain);\n    border-radius: var(--cm-radius-md);\n    padding: .5rem .625rem;\n    font: inherit;\n    line-height: 1;\n    cursor: pointer;\n    transition: background 120ms ease, border-color 120ms ease, transform 120ms ease;\n}\n.chatmd-btn:hover {\n    background: color-mix(in srgb, var(--bf500) 8%, transparent);\n    transform: translateY(-1px);\n}\n.chatmd-btn:active { transform: none; }\n.chatmd-btn:focus-visible { outline: 2px solid var(--bf500); outline-offset: 3px; }\n\n/* ===== Iframe : même logique de hauteur que avant ===== */\n#chatmd-iframe.chatmd-iframe {\n    width: 100%;\n    height: calc(100% - 56px); /* header ? 56px */\n    border: 0;\n    display: block;\n    background: var(--w-bf500);\n}\n\n/* Scrollbar douce (optionnel) */\n#chatmd-panel ::-webkit-scrollbar { width: 10px; }\n#chatmd-panel ::-webkit-scrollbar-thumb {\n    background: color-mix(in srgb, var(--g800-plain) 25%, transparent);\n    border-radius: 6px;\n}\n\n/* Ancrage bas-droite qui contient l'encart + le FAB */\n#chatmd-anchor.chatmd-anchor{\n    position: fixed;\n    inset-inline-end: 20px;\n    inset-block-end: 20px;\n    z-index: var(--cm-z);\n}\n\n/* Le FAB  l'intérieur de l'ancrage n'a plus besoin d'être fixed */\n.chatmd-anchor #chatmd-fab{\n    position: static;\n    inset: auto;\n}\n\n/* Encart au-dessus, collé au coin haut-gauche du FAB */\n#chatmd-teaser.chatmd-teaser{\n    position: absolute;\n    left: auto;          /* au lieu de left:0  */\n    right: 0;            /* aligne l'encart  droite de l'ancrage (donc  l'écran) */\n    bottom: calc(56px + 10px);\n    width: 320px;\n    max-width: calc(100vw - 20px - 56px - 20px); /* garde tout  l'écran: marge droite + FAB + marge */\n    background: var(--w-bf500);\n    color: var(--g800-plain);\n    border: 1px solid var(--g400);\n    border-radius: var(--cm-radius-lg);\n    box-shadow: var(--cm-shadow);\n}\n\n/* Déplace la flèche vers la droite pour pointer la bulle */\n#chatmd-teaser::after{\n    content:\"\";\n    position:absolute;\n    left: auto;          /* plus à gauche */\n    right: 18px;         /* place la flèche à côté de la bulle */\n    bottom: -8px;\n    width: 16px; height: 16px;\n    background: var(--w-bf500);\n    border-bottom: 1px solid var(--g400);\n    transform: rotate(45deg);\n}\n\n.chatmd-teaser-inner{ padding: 16px 14px 14px 14px; }\n.chatmd-teaser-head{ display:flex; align-items:center; justify-content:space-between; gap:.75rem; margin-left:28px; }\n.chatmd-teaser-head strong{ font-size:1.125rem; }\n.chatmd-teaser-avatar{ width:36px; height:36px; border-radius:50%; display:grid; place-items:center; background:#f0f4ff; border:2px solid #dfe6ff; font-size:18px; }\n.chatmd-teaser-sub{ margin:8px 0 10px 28px; color:var(--g600); }\n.chatmd-teaser-cta{ margin-left:28px; font-weight:700; text-decoration:none; color:var(--bf500); --link-underline:none}\n\n.chatmd-teaser-close{\n    position:absolute; top:8px; left:8px; width:28px; height:28px;\n    border:0; border-radius:999px; cursor:pointer;\n    background: var(--g200); color: var(--g800-plain); font-size:18px;\n    line-height:15px;\n}\n.chatmd-teaser-close:hover{ background-color: var(--g300); }\n\n@media (prefers-reduced-motion: no-preference){\n    #chatmd-teaser{ animation: cm-drop .18s ease-out both; transform-origin: 20px 100%; }\n    @keyframes cm-drop{ from{opacity:0; transform: translateY(6px) scale(.98);} to{opacity:1; transform:none;} }\n}\n\n@media (max-width: 420px){\n    #chatmd{ display:none; }\n}\n\n.chatmd-btn.is-reloading [aria-hidden]{\n    display:inline-block;\n    animation: chatmd-rotate 1s linear infinite;\n}\n@keyframes chatmd-rotate { from{ transform: rotate(0deg);} to{ transform: rotate(360deg);} }"
            },
