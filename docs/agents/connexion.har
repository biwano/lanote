            "content": {
              "size": 1315,
              "mimeType": "application/javascript",
              "compression": 0,
              "text": "document.addEventListener('DOMContentLoaded', () => {\n\n    const BLOC = document.getElementById('chatmd-bloc');\n    const URL = \"/educt-aide/agent-conversationnel/chatmd.html\";\n\n    if (!BLOC) return;\n\n    fetch(URL, { credentials: \"same-origin\" })\n        //On récupère le HTML de chatmd\n        .then(r => {\n            if (!r.ok) throw new Error(\"HTTP \" + r.status);\n            return r.text();\n        })\n        .then(html => {\n            //    Insère le fragment dans la page\n            BLOC.innerHTML = html;\n\n            //On récupère les <script> du fragment\n            const scripts = BLOC.querySelectorAll('script');\n\n            scripts.forEach(oldScript => {\n                const newScript = document.createElement('script');\n\n                // Copier tous les attributs (id, src, defer, data-*)\n                for (const attr of oldScript.attributes) {\n                    newScript.setAttribute(attr.name, attr.value);\n                }\n\n                // Si script inline, on copie aussi le code\n                if (!oldScript.src) {\n                    newScript.textContent = oldScript.textContent;\n                }\n\n                // On remplace l'ancien script par le nouveau afin qu'il s'exécute\n                oldScript.replaceWith(newScript);\n            });\n        });\n});\n"
            },
            "redirectURL": "",
