            "cookies": [],
            "content": {
              "size": 7403,
              "mimeType": "text/html",
              "compression": 0,
              "text": "\n\n<!DOCTYPE html>\n<html lang=\"fr\">\n\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1, shrink-to-fit=no\" />\n  <link rel=\"stylesheet\" href=\"/idp-static/dsfr/dsfr.min.css?v=26.2\" />\n  <link rel=\"stylesheet\" href=\"/idp-static/dsfr/utility/utility.min.css?v=26.2\">\n  <link rel=\"stylesheet\" href=\"/idp-static/css/styles-dsfr14.css?v=26.2\" />\n  <link rel=\"stylesheet\" href=\"/idp-static/css/stylesEduConnect.css?v=26.2\" />\n  <link rel=\"stylesheet\" href=\"/idp-static/css/stylesLogosEduConnect.css?v=26.2\" />\n  <link rel=\"icon\" href=\"/idp-static/favicons/favicon.svg\" type=\"image/svg+xml\" />\n  <link rel=\"shortcut icon\" href=\"/idp-static/favicons/favicon.ico\" type=\"image/x-icon\" />\n  <link rel=\"manifest\" href=\"/idp-static/favicons/manifest.webmanifest\" crossorigin=\"use-credentials\" />\n\n  <script src=\"/idp-static/js/jquery.min.js?v=26.2\"></script>\n  <script src=\"/idp-static/js/cookie.js?v=26.2\"></script>\n\n  <title>Déconnexion du compte - ÉduConnect</title>\n\n\t<script>\n\t\tsessionStorage.removeItem('profilEduConnect');\n\t\t$(document).ready(function(){\n\t\t});\n\t</script>\n</head>\n\n<body class=\"fr-header-padding-top--minimized\">\n  <div class=\"fr-skiplinks\">\n    <nav class=\"fr-container\" role=\"navigation\" aria-label=\"Accès rapide\">\n      <ul class=\"fr-skiplinks__list\">\n        <li>\n          <a class=\"fr-link\" href=\"#contenu\">Contenu</a>\n        </li>\n        <li>\n          <a class=\"fr-link\" href=\"#footer\">Pied de page</a>\n        </li>\n      </ul>\n    </nav>\n  </div>\n\n  <header role=\"banner\" class=\"fr-header js-header no-shadow minify\">\n    <div class=\"fr-header__body\">\n      <div class=\"fr-container\">\n        <div class=\"fr-header__body-row\">\n          <div class=\"fr-header__brand\">\n            <div class=\"fr-header__brand-top wauto-md\">\n              <div class=\"fr-header__logo d-flex-column align-left\">\n                <img id=\"logo-marianne\" src=\"/idp-static/img/logo.png\" alt=\"\" class=\"logo-marianne\" />\n              </div>\n            </div>\n            <div class=\"fr-header__service wauto-md no-shadow\">\n              <p id=\"titreEduConnect\" class=\"fr-header__service-title\" id=\"titre\">ÉduConnect</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </header>\n\n  <div id=\"contenu\" role=\"main\" class=\"fr-container height-auto\">\n    <div class=\"fr-grid-row\">\n      <div class=\"fr-col-md-8 fr-col-12 m-auto\">\n        <div class=\"fr-grid-row fr-grid-row--gutters\">\n          <div class=\"fr-col-12 fr-pt-1w fr-pb-1v\">\n            <h1 id=\"titreDeconnexion\">Déconnexion</h1>\n          </div>\n\n\n\n\n          <div class=\"fr-col-12\">\n            <div class=\"fr-callout success no-margin\" id=\"texteDeconnexion\">\n              <p class=\"fr-callout__title\">Vous avez été déconnecté(e) avec succès</p>\n              <p class=\"fr-callout__text fs-14\">Vous êtes maintenant déconnecté(e) de votre compte ÉduConnect. Merci de votre visite.</p>\n            </div>\n            <div id=\"liens\">\n              <div class=\"fr-card fr-card--no-arrow\">\n                <div class=\"fr-card__body\">\n                  <div class=\"text-center\">\n                    <a href=\"https://moncompte.educonnect.education.gouv.fr/educt-self-service/connexion/controlesConnexion\" id=\"reconnexionWebapp\" class=\"fr-btn\">Se reconnecter à mon compte</a>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n                <!-- Complete the flow by adding a hidden iframe. -->\n\t\t  <iframe style=\"display:none\" src=\"/idp/profile/Logout?execution=e2s2&_eventId=proceed\"></iframe>\n        </div>\n      </div>\n    </div>\n  </div>\n\n<link rel=\"stylesheet\" href=\"/idp-static/css/chatmd.css\" />\n\n<div id=\"chatmd\" hidden>\n    <div id=\"chatmd-bloc\"></div>\n</div>\n\n<script src=\"/idp-static/js/affichageChatMd.js?v=26.2\" defer></script>\n\n<footer class=\"fr-footer\" role=\"contentinfo\" id=\"footer\">\n  <div class=\"fr-container\">\n    <div class=\"fr-footer__body baseline\">\n      <div>\n        <div class=\"fr-footer__brand\">\n            <img id=\"logo-ministere\" src=\"/idp-static/img/logo-ministere.png\" alt=\"\" class=\"fr-logo logo-ministere-large\" />\n        </div>\n        <div>\n            <img src=\"/idp-static/img/relance-fr-ue.svg\" class=\"img-france-relance\" alt=\"\" aria-hidden=\"true\" />\n        </div>\n      </div>\n      <div class=\"fr-footer__content fr-mt-5v\">\n        <p class=\"fr-footer__content-desc\" id=\"descriptionApplication\">Un compte unique pour les services numériques des écoles et des établissements</p>\n        <ul class=\"fr-footer__content-list\">\n          <li class=\"fr-footer__content-item\">\n            <a class=\"fr-footer__content-link\" id=\"lienEducationGouv\" href=\"https://education.gouv.fr\" aria-label=\"education.gouv.fr - nouvelle fenêtre\" target=\"_blank\">education.gouv.fr</a>\n          </li>\n          <li class=\"fr-footer__content-item\">\n            <a class=\"fr-footer__content-link\" id=\"lienServicePublic\" href=\"https://service-public.fr\" aria-label=\"service-public.fr - nouvelle fenêtre\" target=\"_blank\">service-public.fr</a>\n          </li>\n          <li class=\"fr-footer__content-item\">\n            <a class=\"fr-footer__content-link\" id=\"lienLegifrance\" href=\"https://legifrance.gouv.fr\" aria-label=\"legifrance.gouv.fr - nouvelle fenêtre\" target=\"_blank\">legifrance.gouv.fr</a>\n          </li>\n          <li class=\"fr-footer__content-item\">\n            <a class=\"fr-footer__content-link\" id=\"lienFranceconnect\" href=\"https://franceconnect.gouv.fr\" aria-label=\"franceconnect.gouv.fr - nouvelle fenêtre\" target=\"_blank\">franceconnect.gouv.fr</a>\n          </li>\n        </ul>\n      </div>\n    </div>\n    <div class=\"fr-footer__bottom\">\n      <ul class=\"fr-footer__bottom-list\">\n         <li class=\"fr-footer__bottom-item\">\n           <a id=\"lienAide\" class=\"fr-footer__bottom-link\" href=\"/educt-aide/aide/\" target=\"_blank\" aria-label=\"Besoin d’aide - nouvelle fenêtre\">Besoin d’aide&#8239;?</a>\n         </li>\n         <li class=\"fr-footer__bottom-item\">\n           <a id=\"lienAccessibilite\" class=\"fr-footer__bottom-link\" href=\"/educt-aide/conformite/public.html\" target=\"_blank\" aria-label=\"Accessibilité : partiellement conforme - nouvelle fenêtre\">Accessibilité&nbsp;: partiellement conforme</a>\n         </li>\n         <li class=\"fr-footer__bottom-item\">\n           <a id=\"lienMentions\" class=\"fr-footer__bottom-link\" href=\"/educt-aide/mentions/\" target=\"_blank\" aria-label=\"Mentions légales - nouvelle fenêtre\">Mentions légales</a>\n         </li>\n         <li class=\"fr-footer__bottom-item\">\n           <a id=\"lienMentionsInformatives\" class=\"fr-footer__bottom-link\" href=\"https://educonnect.education.gouv.fr/educt-aide/informations/\" target=\"_blank\" aria-label=\"Mentions informatives - nouvelle fenêtre\">Mentions informatives</a>\n         </li>\n        <li class=\"fr-footer__bottom-item\">\n\t       <span id=\"version\" class=\"fr-footer__bottom-link\">26.2</span>\n\t     </li>\n      </ul>\n      <div class=\"fr-footer__bottom-copy\">\n        <p id=\"copyright\"></p>\n      </div>\n    </div>\n  </div>\n</footer>\n\n<script type=\"module\" src=\"/idp-static/dsfr/dsfr.module.min.js?v=26.2\"></script>\n<script type=\"text/javascript\" nomodule src=\"/idp-static/dsfr/dsfr.nomodule.min.js?v=26.2\"></script>\n<script src=\"/idp-static/js/menujs.js?v=26.2\"></script>\n<script src=\"/idp-static/js/affichageCopyright.js?v=26.2\"></script>\n<script>\n</script>\n  </body>\n</html>"
